<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Portal Oficial — Juan Manuel Fructuoso Heredia</title>
  <style>
    :root { --bg-deep: #0f1117; --bg-card: #181c27; --accent: #7eb8c4; --text-primary: #e8eaf0; --text-secondary: #9aa3b8; --gold: #c9a84c; --border: #2a3048; }
    body { background: var(--bg-deep); color: var(--text-primary); font-family: sans-serif; margin: 0; line-height: 1.6; scroll-behavior: smooth; }
    .nav { position: sticky; top: 0; background: #0f1117; padding: 15px; border-bottom: 1px solid var(--border); text-align: center; z-index: 100; }
    .nav a { color: var(--text-secondary); margin: 0 10px; text-decoration: none; font-size: 0.9rem; }
    .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }
    section { padding-top: 60px; }
    .section-title { color: var(--accent); font-size: 1.8rem; margin-bottom: 25px; border-bottom: 1px solid var(--border); display: inline-block; }
    .grid { display: grid; grid-template-columns: 1fr; gap: 20px; }
    .card { background: var(--bg-card); padding: 25px; border-radius: 12px; border: 1px solid var(--border); }
    .btn-gold { display: block; background: var(--gold); color: #000; padding: 15px; border-radius: 8px; text-align: center; text-decoration: none; font-weight: bold; margin-top: 15px; }
  </style>
</head>
<body>
  <nav class="nav">
    <a href="#inicio">Inicio</a>
    <a href="#libros">Libros</a>
    <a href="#eventos">Eventos</a>
    <a href="#noticias">Noticias</a>
    <a href="#biografia">Biografía</a>
  </nav>
  
  <div class="container">
    <section id="inicio">
      <h1><%= autor.nombre %></h1>
      <p><%= autor.tagline %></p>
    </section>

    <section id="libros">
      <h2 class="section-title">Mis Libros</h2>
      <div class="grid">
        <% libros.forEach(libro => { %>
          <div class="card">
            <h3><%= libro.titulo %></h3>
            <p><%= libro.sinopsis %></p>
            <a href="<%= libro.enlace %>" class="btn-gold">COMPRAR EN AMAZON</a>
          </div>
        <% }) %>
      </div>
    </section>

    <section id="eventos">
      <h2 class="section-title">Próximos Eventos</h2>
      <% eventos.forEach(evento => { %>
        <div class="card" style="margin-bottom:15px;">
          <h3><%= evento.titulo %></h3>
          <p><%= evento.lugar %> | <%= evento.fecha %></p>
        </div>
      <% }) %>
    </section>

    <section id="noticias">
      <h2 class="section-title">Noticias Recientes</h2>
      <div class="grid">
        <% noticias.forEach(noticia => { %>
          <div class="card">
            <h3><%= noticia.titulo %></h3>
            <p><%= noticia.resumen %></p>
          </div>
        <% }) %>
      </div>
    </section>

    <section id="biografia">
      <h2 class="section-title">Biografía</h2>
      <div class="card"><p><%= autor.biografia %></p></div>
    </section>
  </div>
</body>
</html>
