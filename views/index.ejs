<!-- views/index.ejs -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= titulo %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <header class="main-header">
            <h1>General Juan Fructuoso Heredia</h1>
            <nav class="main-nav">
                <a href="/">Inicio</a>
                <a href="/perfil">Ver Perfil Completo</a>
            </nav>
        </header>

        <main class="content-wrapper">
            <section class="hero">
                <h2>Bienvenido al Portal Oficial</h2>
                <div class="divider"></div>
                <p><%= mensaje %></p>
            </section>

            <section class="info-section">
                <div class="card">
                    <h3>Documentación Histórica</h3>
                    <p>Acceso a la trayectoria y archivos oficiales del General.</p>
                </div>
            </section>
        </main>

        <footer class="main-footer">
            <p>&copy; 2026 Sitio Oficial del General</p>
        </footer>
    </div>
</body>
</html>
