<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inicio — Juan Manuel Fructuoso Heredia</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="nav"><a href="/" class="nav-brand">Juan Manuel Fructuoso Heredia</a></nav>
  
  <div class="container">
    <section class="hero">
      <h1><%= autor.nombre %></h1>
      <p class="hero-tagline"><%= autor.tagline %></p>
    </section>

    <section>
      <h2 class="section-title">Mis Libros</h2>
      <div class="books-grid">
        <% libros.forEach(libro => { %>
          <div class="book-card">
            <h3><%= libro.titulo %></h3>
            <p><%= libro.sinopsis %></p>
            <span class="book-price"><%= libro.precio %></span>
            <a href="<%= libro.enlace %>" class="btn-gold">Comprar en Amazon</a>
          </div>
        <% }) %>
      </div>
    </section>

    <section style="margin-top:50px;">
      <h2 class="section-title">Próximos Eventos</h2>
      <% eventos.forEach(evento => { %>
        <div class="event-card">
          <h3><%= evento.titulo %></h3>
          <p><%= evento.lugar %></p>
        </div>
      <% }) %>
    </section>
  </div>
</body>
</html>
