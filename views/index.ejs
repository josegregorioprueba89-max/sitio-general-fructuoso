<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Portal Oficial — Juan Manuel Fructuoso Heredia</title>
  <style>
    :root { --bg-deep: #0f1117; --bg-card: #181c27; --accent: #7eb8c4; --text-primary: #e8eaf0; --text-secondary: #9aa3b8; --gold: #c9a84c; --border: #2a3048; }
    body { background: var(--bg-deep); color: var(--text-primary); font-family: sans-serif; margin: 0; line-height: 1.6; }
    .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }
    .nav { padding: 20px; text-align: center; border-bottom: 1px solid var(--border); }
    .nav-brand { color: var(--accent); font-size: 1.5rem; text-decoration: none; font-weight: bold; }
    .hero { padding: 60px 0; text-align: center; }
    h1 { color: var(--accent); font-size: 2.5rem; margin-bottom: 10px; }
    .section-title { color: var(--accent); font-size: 1.8rem; margin-top: 40px; margin-bottom: 20px; border-bottom: 1px solid var(--border); display: inline-block; }
    .grid { display: grid; grid-template-columns: 1fr; gap: 20px; }
    .card { background: var(--bg-card); padding: 20px; border-radius: 12px; border: 1px solid var(--border); }
    .btn-gold { display: block; background: var(--gold); color: #000; padding: 12px; border-radius: 8px; text-align: center; text-decoration: none; font-weight: bold; margin-top: 15px; }
  </style>
</head>
<body>
  <nav class="nav"><a href="/" class="nav-brand">Juan Manuel Fructuoso Heredia</a></nav>
  
  <div class="container">
    <section class="hero">
      <h1><%= autor.nombre %></h1>
      <p><%= autor.tagline %></p>
    </section>

    <section>
      <h2 class="section-title">Mis Libros</h2>
      <div class="grid">
        <% libros.forEach(libro => { %>
          <div class="card">
            <h3><%= libro.titulo %></h3>
            <p><%= libro.sinopsis %></p>
            <a href="<%= libro.enlace %>" class="btn-gold">VER LIBRO</a>
          </div>
        <% }) %>
      </div>
    </section>

    <section>
      <h2 class="section-title">Próximos Eventos</h2>
      <% eventos.forEach(evento => { %>
        <div class="card" style="margin-bottom:10px;">
          <h3><%= evento.titulo %></h3>
          <p><%= evento.lugar %> | <%= evento.fecha %></p>
        </div>
      <% }) %>
    </section>

    <section>
      <h2 class="section-title">Noticias Recientes</h2>
      <div class="grid">
        <% noticias.forEach(noticia => { %>
          <div class="card">
            <h3><%= noticia.titulo %></h3>
            <p><%= noticia.resumen %></p>
          </div>
        <% }) %>
      </div>
    </section>

    <section>
      <h2 class="section-title">Biografía</h2>
      <div class="card"><p><%= autor.biografia %></p></div>
    </section>

    <section>
      <h2 class="section-title">Galería</h2>
      <div class="grid">
        <div class="card"><p>Espacio reservado para imágenes del General.</p></div>
      </div>
    </section>
  </div>
</body>
</html>
