<!-- views/index.ejs -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= titulo %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="main-container">
        <header class="top-nav">
            <h1>General Juan Fructuoso Heredia</h1>
            <nav>
                <a href="/">Inicio</a>
                <a href="/perfil">Perfil Profesional</a>
            </nav>
        </header>

        <main class="grid-layout">
            <!-- Sección Principal -->
            <section class="hero-box">
                <h2>Portal Oficial</h2>
                <p><%= mensaje %></p>
            </section>

            <!-- Sección de Documentación (Espacio separado) -->
            <section class="content-box">
                <h3>Documentación Histórica</h3>
                <p>Aquí encontrará la cronología detallada y archivos de referencia del General.</p>
                <button class="btn-primary">Ver Archivos</button>
            </section>
        </main>
    </div>
</body>
</html>
