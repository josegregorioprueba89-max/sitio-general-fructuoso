<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Registro — Juan Manuel Fructuoso Heredia</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      Juan Manuel Fructuoso Heredia
      <span>General (r) · Abogado · Escritor</span>
    </a>
    <ul class="nav-links">
      <li><a href="/">Inicio</a></li>
      <li><a href="/libros">Libros</a></li>
      <li><a href="/biografia">Biografía</a></li>
      <li><a href="/eventos">Eventos</a></li>
      <li><a href="/galeria">Galería</a></li>
      <li><a href="/registro" class="nav-cta">Registrarse</a></li>
    </ul>
  </div>
</nav>

<div class="auth-wrapper">
  <div class="auth-card">

    <h1 class="auth-title">Crear cuenta</h1>
    <p class="auth-subtitle">Únete a la comunidad de lectores de <%= autor.nombre %></p>

    <!-- MENSAJE DE ERROR -->
    <% if (error) { %>
    <div class="form-error" role="alert">
      ⚠️ <%= error %>
    </div>
    <% } %>

    <!-- MENSAJE DE ÉXITO -->
    <% if (mensaje) { %>
    <div class="form-success" role="status">
      ✅ <%= mensaje %>
    </div>
    <a href="/" class="btn btn-primary btn-full" style="margin-top:16px;">
      Ir al inicio
    </a>

    <% } else { %>

    <!-- FORMULARIO -->
    <form action="/registro" method="POST" novalidate>

      <div class="form-group">
        <label class="form-label" for="nombre">Nombre completo</label>
        <input
          class="form-input"
          type="text"
          id="nombre"
          name="nombre"
          placeholder="Tu nombre completo"
          value="<%= typeof nombreVal !== 'undefined' ? nombreVal : '' %>"
          autocomplete="name"
          required
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="email">Correo electrónico</label>
        <input
          class="form-input"
          type="email"
          id="email"
          name="email"
          placeholder="tu@correo.com"
          value="<%= typeof emailVal !== 'undefined' ? emailVal : '' %>"
          autocomplete="email"
          required
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="password">Contraseña</label>
        <input
          class="form-input"
          type="password"
          id="password"
          name="password"
          placeholder="Mínimo 8 caracteres"
          autocomplete="new-password"
          required
          minlength="8"
        />
        <span style="font-size:0.75rem; color:var(--text-muted); margin-top:5px; display:block;">
          Mínimo 8 caracteres.
        </span>
      </div>

      <div class="form-group">
        <label class="form-label" for="password2">Confirmar contraseña</label>
        <input
          class="form-input"
          type="password"
          id="password2"
          name="password2"
          placeholder="Repite tu contraseña"
          autocomplete="new-password"
          required
        />
      </div>

      <button type="submit" class="btn btn-primary btn-full">
        Crear cuenta
      </button>
    </form>

    <p style="text-align:center; margin-top:20px; font-size:0.83rem; color:var(--text-muted);">
      ¿Ya tienes cuenta? <a href="/">Volver al inicio</a>
    </p>

    <% } %>
  </div>
</div>

<footer class="footer">
  <div class="container">
    <div class="footer-name">Juan Manuel Fructuoso Heredia</div>
    <ul class="footer-links">
      <li><a href="/">Inicio</a></li>
      <li><a href="/libros">Libros</a></li>
      <li><a href="/biografia">Biografía</a></li>
      <li><a href="/eventos">Eventos</a></li>
      <li><a href="/galeria">Galería</a></li>
    </ul>
    <p class="footer-copy">&copy; <%= new Date().getFullYear() %> Juan Manuel Fructuoso Heredia. Todos los derechos reservados.</p>
  </div>
</footer>

</body>
</html>
