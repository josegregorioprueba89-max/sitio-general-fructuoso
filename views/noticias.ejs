<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Noticias — Juan Manuel Fructuoso Heredia</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      Juan Manuel Fructuoso Heredia
      <span>General (r) · Abogado · Escritor</span>
    </a>
    <ul class="nav-links">
      <li><a href="/">Inicio</a></li>
      <li><a href="/libros">Libros</a></li>
      <li><a href="/biografia">Biografía</a></li>
      <li><a href="/eventos">Eventos</a></li>
      <li><a href="/noticias" class="active">Noticias</a></li>
      <li><a href="/galeria">Galería</a></li>
      <li><a href="/contacto">Contacto</a></li>
      <li><a href="/registro" class="nav-cta">Registrarse</a></li>
    </ul>
  </div>
</nav>

<div class="container">
  <div class="page-header">
    <span class="section-label">Novedades</span>
    <h1>Noticias</h1>
    <p>Últimas novedades, entrevistas y cobertura mediática del autor.</p>
  </div>

  <% if (noticias.length === 0) { %>
  <div style="text-align:center; padding:80px 0; color:var(--text-muted);">
    <span style="font-size:3rem;">📰</span>
    <p style="margin-top:16px;">No hay noticias publicadas aún.</p>
  </div>
  <% } else { %>
  <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(320px, 1fr)); gap:28px; margin-bottom:72px;">
    <% noticias.forEach(noticia => { %>
    <div class="card" style="display:flex; flex-direction:column; gap:16px; padding:0; overflow:hidden;">
      <div style="width:100%; aspect-ratio:16/9; background:var(--bg-subtle); display:flex; align-items:center; justify-content:center; color:var(--text-muted); font-size:2rem;">
        📰
      </div>
      <div style="padding:20px 24px 24px;">
        <p style="font-size:0.7rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:var(--accent); margin-bottom:8px;"><%= noticia.fecha %></p>
        <h2 style="font-family:var(--font-display); font-size:1.1rem; font-weight:700; color:var(--text-primary); margin-bottom:10px; line-height:1.35;"><%= noticia.titulo %></h2>
        <p style="font-size:0.85rem; color:var(--text-secondary); line-height:1.65; margin-bottom:16px;"><%= noticia.resumen %></p>
        <p style="font-size:0.85rem; color:var(--text-secondary); line-height:1.7;"><%= noticia.contenido %></p>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>

<a href="https://wa.me/18093041128" target="_blank" rel="noopener"
   style="position:fixed; bottom:28px; right:28px; z-index:999;
          background:#25d366; color:#fff; border-radius:50%;
          width:60px; height:60px; display:flex; align-items:center; justify-content:center;
          font-size:1.8rem; box-shadow:0 4px 20px rgba(37,211,102,0.45);
          text-decoration:none; transition:transform 0.2s ease;"
   onmouseover="this.style.transform='scale(1.1)'"
   onmouseout="this.style.transform='scale(1)'"
   title="Contactar por WhatsApp">💬</a>

<footer class="footer">
  <div class="container">
    <div class="footer-name">Juan Manuel Fructuoso Heredia</div>
    <ul class="footer-links">
      <li><a href="/">Inicio</a></li>
      <li><a href="/libros">Libros</a></li>
      <li><a href="/biografia">Biografía</a></li>
      <li><a href="/eventos">Eventos</a></li>
      <li><a href="/noticias">Noticias</a></li>
      <li><a href="/galeria">Galería</a></li>
      <li><a href="/contacto">Contacto</a></li>
    </ul>
    <p class="footer-copy">&copy; <%= new Date().getFullYear() %> Juan Manuel Fructuoso Heredia. Todos los derechos reservados.</p>
  </div>
</footer>
</body>
</html>
