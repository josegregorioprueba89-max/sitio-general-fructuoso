<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= libro.titulo %> — Juan Manuel Fructuoso Heredia</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      Juan Manuel Fructuoso Heredia
      <span>General (r) · Abogado · Escritor</span>
    </a>
    <ul class="nav-links">
      <li><a href="/">Inicio</a></li>
      <li><a href="/libros" class="active">Libros</a></li>
      <li><a href="/biografia">Biografía</a></li>
      <li><a href="/eventos">Eventos</a></li>
      <li><a href="/galeria">Galería</a></li>
    </ul>
  </div>
</nav>

<div class="container">
  <div class="page-header">
    <a href="/libros" style="color:var(--text-muted); text-decoration:none;">← Volver a libros</a>
    <span class="section-label" style="margin-top:20px;"><%= libro.genero %></span>
    <h1><%= libro.titulo %></h1>
    <p><%= libro.subtitulo %> · <%= libro.anio %> · <%= libro.paginas %> páginas</p>
  </div>

  <div style="display:grid; grid-template-columns: 1fr; gap:48px;">
    <!-- Portada y Compra -->
    <div>
      <div class="book-cover-placeholder">
        <span class="book-icon">📖</span>
        <span><%= libro.titulo %></span>
      </div>
      <a href="<%= libro.enlaceAmazon %>" target="_blank" class="btn btn-gold btn-full">
        Comprar en Amazon — <%= libro.precio %>
      </a>
    </div>

    <!-- Detalles -->
    <div>
      <h2 style="font-family:var(--font-display);">Sinopsis</h2>
      <p style="margin-top:20px;"><%= libro.sinopsis %></p>
      
      <div style="margin-top:30px; background:var(--bg-subtle); padding:20px; border-radius:var(--radius);">
        <p>📅 Año: <strong><%= libro.anio %></strong></p>
        <p>📄 Páginas: <strong><%= libro.paginas %></strong></p>
      </div>
    </div>
  </div>
</div>

</body>
</html>
